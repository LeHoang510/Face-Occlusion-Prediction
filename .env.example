# Copy to .env and fill in. cluster_exec.sh sync-env / submit will push this
# file to the cluster (it is excluded from rsync by default and only sent
# explicitly).
#
# WandB
WANDB_API_KEY=
WANDB_MODE=online            # online | offline | disabled

# HuggingFace (DINOv3 weights are gated — request access on the model page)
HF_TOKEN=

# Optional cache overrides; defaults are set in scripts/slurm/_common.sh
# HF_HOME=
# TORCH_HOME=
